# LocalCrab environment — copy to .env and fill in values
# cp .env.example .env

# Tailscale (optional — leave blank to skip)
TS_AUTHKEY=
TS_HOSTNAME=localcrab

# Ralph Wiggum loop settings
RALPH_CHECK_IN_INTERVAL=12
RALPH_STALL_TIMEOUT=45
RALPH_MAX_RETRIES=3
RALPH_TASK_HARD_LIMIT=600

# Telegram bot (optional — leave blank to disable)
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot
# Leave blank to allow everyone (not recommended for public bots)
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=
