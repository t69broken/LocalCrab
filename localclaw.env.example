# LocalCrab — bare-metal environment (used when running outside Docker)
# Copy to localclaw.env and adjust paths for your system
# cp localclaw.env.example localclaw.env

# Paths (adjust to your install location)
MEMORY_DB=/home/YOUR_USER/localcrab/data/memory/memory.db
HISTORY_DB=/home/YOUR_USER/localcrab/data/history/history.db
TASKS_DB=/home/YOUR_USER/localcrab/data/history/tasks.db
SKILLS_DIR=/home/YOUR_USER/localcrab/data/skills
PERSONAS_DIR=/home/YOUR_USER/localcrab/data/personas
COMMS_CONFIG=/home/YOUR_USER/localcrab/data/comms_config.json
PYTHONPATH=/home/YOUR_USER/localcrab/src

# Ollama (direct — no Docker networking needed)
OLLAMA_BASE_URL=http://localhost:11434

# Ralph Wiggum loop
RALPH_CHECK_IN_INTERVAL=12
RALPH_STALL_TIMEOUT=45
RALPH_MAX_RETRIES=3
RALPH_TASK_HARD_LIMIT=600
